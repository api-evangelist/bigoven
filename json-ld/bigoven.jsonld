{
  "@context": {
    "@vocab": "https://schema.org/",
    "bigoven": "https://api2.bigoven.com/vocab#",
    "openapi": "https://openapis.org/schema#"
  },
  "@type": "WebAPI",
  "@id": "https://api2.bigoven.com",
  "name": "1,000,000+ Recipe and Grocery List API (v2)",
  "description": "REST API providing access to 1,000,000+ recipes, grocery list management, nutritional data, and meal planning features.",
  "url": "https://api2.bigoven.com",
  "documentation": "https://api2.bigoven.com/web/documentation",
  "version": "partner",
  "provider": {
    "@type": "Organization",
    "name": "BigOven / Aisle Ahead, Inc.",
    "url": "https://www.bigoven.com"
  },
  "offers": {
    "@type": "Offer",
    "url": "https://api2.bigoven.com/web/documentation/feestructure"
  },
  "potentialAction": [
    {
      "@type": "SearchAction",
      "name": "Recipe Search",
      "description": "Search over 1,000,000 recipes by keyword, cuisine, dietary restriction, and more",
      "target": "https://api2.bigoven.com/recipe"
    },
    {
      "@type": "ReadAction",
      "name": "Get Recipe",
      "description": "Retrieve a specific recipe by ID with full nutritional information",
      "target": "https://api2.bigoven.com/recipe/{recipe-id}"
    },
    {
      "@type": "ReadAction",
      "name": "Grocery List",
      "description": "Read and manage cloud-based grocery lists",
      "target": "https://api2.bigoven.com/grocerylist"
    }
  ],
  "keywords": [
    "recipes",
    "meal planning",
    "grocery lists",
    "nutrition",
    "food",
    "cooking"
  ],
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceUrl": "https://api2.bigoven.com",
    "availableLanguage": "en"
  },
  "termsOfService": "https://api2.bigoven.com/web/documentation",
